msgstr "Действия на Accessibility Checker"

#: build/sidebar.bundle.js:2
msgid "Scan"
msgstr "Сканиране"

#: build/sidebar.bundle.js:2
msgid "Refresh"
msgstr "Обновяване"

#: build/srOnlyFormat.bundle.js:2
msgid "Screen Reader Only"
msgstr "Само за екранен четец"

#: build/srOnlyFormat.bundle.js:2
