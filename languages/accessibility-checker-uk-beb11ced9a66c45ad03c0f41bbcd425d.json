\u043f\u043d\u043e"],"Warning":["\u041f\u043e\u043f\u0435\u0440\u0435\u0434\u0436\u0435\u043d\u043d\u044f"],"This post does not contain enough content to calculate a reading level.":["\u0426\u0435\u0439 \u0434\u043e\u043f\u0438\u0441 \u043d\u0435 \u043c\u0456\u0441\u0442\u0438\u0442\u044c \u0434\u043e\u0441\u0442\u0430\u0442\u043d\u044c\u043e \u0432\u043c\u0456\u0441\u0442\u0443 \u0434\u043b\u044f \u0440\u043e\u0437\u0440\u0430\u0445\u0443\u043d\u043a\u0443 \u0440\u0456\u0432\u043d\u044f \u0447\u0438\u0442\u0430\u043d\u043d\u044f."],"Adjust summary prompts in settings.":["\u041d\u0430\u043b\u0430\u0448\u0442\u0443\u0439\u0442\u0435 \u043f\u0456\u0434\u043a\u0430\u0437\u043a\u0438 \u0440\u0435\u0437\u044e\u043c\u0435 \u0432 \u043d\u0430\u043b\u0430\u0448\u0442\u0443\u0432\u0430\u043d\u043d\u044f\u0445."],"Content at or below a 9th-grade reading level does not require a simplified summary.":["\u0412\u043c\u0456\u0441\u0442 \u043d\u0430 \u0440\u0456\u0432\u043d\u0456 \u0447\u0438\u0442\u0430\u043d\u043d\u044f 9-\u0433\u043e \u043a\u043b\u0430\u0441\u0443 \u0430\u0431\u043e \u043d\u0438\u0436\u0447\u0435 \u043d\u0435 \u043f\u043e\u0442\u0440\u0435\u0431\u0443\u0454 \u0441\u043f\u0440\u043e\u0449\u0435\u043d\u043e\u0433\u043e \u0440\u0435\u0437\u044e\u043c\u0435."],"Content above a 9th-grade reading level requires a simplified summary to meet WCAG AAA guidance.":["\u0412\u043c\u0456\u0441\u0442 \u0432\u0438\u0449\u0435 \u0440\u0456\u0432\u043d\u044f \u0447\u0438\u0442\u0430\u043d\u043d\u044f 9-\u0433\u043e \u043a\u043b\u0430\u0441\u0443 \u043f\u043e\u0442\u0440\u0435\u0431\u0443\u0454 \u0441\u043f\u0440\u043e\u0449\u0435\u043d\u043e\u0433\u043e \u0440\u0435\u0437\u044e\u043c\u0435 \u0434\u043b\u044f \u0432\u0456\u0434\u043f\u043e\u0432\u0456\u0434\u043d\u043e\u0441\u0442\u0456 \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0430\u0446\u0456\u044f\u043c WCAG AAA."],"Learn more about readability requirements.":["\u0414\u0456\u0437\u043d\u0430\u0439\u0442\u0435\u0441\u044f \u0431\u0456\u043b\u044c\u0448\u0435 \u043f\u0440\u043e \u0432\u0438\u043c\u043e\u0433\u0438 \u0434\u043e \u0447\u0438\u0442\u0430\u0431\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0456."],"Simplified Summary Reading Level":["\u0420\u0456\u0432\u0435\u043d\u044c \u0447\u0438\u0442\u0430\u043d\u043d\u044f \u0441\u043f\u0440\u043e\u0449\u0435\u043d\u043e\u0433\u043e \u0440\u0435\u0437\u044e\u043c\u0435"],"Needs improvement, summary is above the 9th-grade reading level.":["\u041f\u043e\u0442\u0440\u0435\u0431\u0443\u0454 \u043f\u043e\u043a\u0440\u0430\u0449\u0435\u043d\u043d\u044f, \u0440\u0435\u0437\u044e\u043c\u0435 \u0432\u0438\u0449\u0435 \u0440\u0456\u0432\u043d\u044f \u0447\u0438\u0442\u0430\u043d\u043d\u044f 9-\u0433\u043e \u043a\u043b\u0430\u0441\u0443."],"Below the recommended 9th-grade reading level.":["\u041d\u0438\u0436\u0447\u0435 \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u043e\u0432\u0430\u043d\u043e\u0433\u043e \u0440\u0456\u0432\u043d\u044f \u0447\u0438\u0442\u0430\u043d\u043d\u044f 9-\u0433\u043e \u043a\u043b\u0430\u0441\u0443."],"Enter simplified summary...":["\u0412\u0432\u0435\u0434\u0456\u0442\u044c \u0441\u043f\u0440\u043e\u0449\u0435\u043d\u0435 \u0440\u0435\u0437\u044e\u043c\u0435..."],"A simplified summary is required for this content.":["\u0414\u043b\u044f \u0446\u044c\u043e\u0433\u043e \u0432\u043c\u0456\u0441\u0442\u0443 \u043f\u043e\u0442\u0440\u0456\u0431\u0435\u043d \u0441\u043f\u0440\u043e\u0449\u0435\u043d\u0438\u0439 \u043f\u0456\u0434\u0441\u0443\u043c\u043e\u043a."],"Unable to load this preference.":["\u041d\u0435 \u0432\u0434\u0430\u043b\u043e\u0441\u044f \u0437\u0430\u0432\u0430\u043d\u0442\u0430\u0436\u0438\u0442\u0438 \u0446\u044e \u043f\u0435\u0440\u0435\u0432\u0430\u0433\u0443."],"Unable to save this preference.":["\u041d\u0435 \u0432\u0434\u0430\u043b\u043e\u0441\u044f \u0437\u0431\u0435\u0440\u0435\u0433\u0442\u0438 \u0446\u044e \u043f\u0435\u0440\u0435\u0432\u0430\u0433\u0443."],"Loading preference...":["\u0417\u0430\u0432\u0430\u043d\u0442\u0430\u0436\u0435\u043d\u043d\u044f \u043f\u0435\u0440\u0435\u0432\u0430\u0433\u0438..."],"Screen Reader Text Format":["\u0424\u043e\u0440\u043c\u0430\u0442 \u0442\u0435\u043a\u0441\u0442\u0443 \u0434\u043b\u044f \u0437\u0447\u0438\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0437 \u0435\u043a\u0440\u0430\u043d\u0430"],"Control whether screen reader text stays visible while you edit.":["\u041a\u0435\u0440\u0443\u0439\u0442\u0435 \u0432\u0438\u0434\u0438\u043c\u0456\u0441\u0442\u044e \u0442\u0435\u043a\u0441\u0442\u0443 \u0434\u043b\u044f \u0437\u0447\u0438\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0437 \u0435\u043a\u0440\u0430\u043d\u0430 \u043f\u0456\u0434 \u0447\u0430\u0441 \u0440\u0435\u0434\u0430\u0433\u0443\u0432\u0430\u043d\u043d\u044f."],"Always show screen reader text?":["\u0417\u0430\u0432\u0436\u0434\u0438 \u043f\u043e\u043a\u0430\u0437\u0443\u0432\u0430\u0442\u0438 \u0442\u0435\u043a\u0441\u0442 \u0434\u043b\u044f \u0437\u0447\u0438\u0442\u0443\u0432\u0430\u043d\u043d\u044f \u0437 \u0435\u043a\u0440\u0430\u043d\u0430?"],"Loading accessibility data...":["\u0417\u0430\u0432\u0430\u043d\u0442\u0430\u0436\u0435\u043d\u043d\u044f \u0434\u0430\u043d\u0438\u0445 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0456..."],"Accessibility Checker actions":["\u0414\u0456\u0457 Accessibility Checker"],"Scan":["\u0421\u043a\u0430\u043d\u0443\u0432\u0430\u0442\u0438"],"Refresh":["\u041e\u043d\u043e\u0432\u0438\u0442\u0438"]}}}