nough content to calculate a reading level.":["\u042d\u0442\u043e\u0442 \u043f\u043e\u0441\u0442 \u043d\u0435 \u0441\u043e\u0434\u0435\u0440\u0436\u0438\u0442 \u0434\u043e\u0441\u0442\u0430\u0442\u043e\u0447\u043d\u043e\u0433\u043e \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u0430 \u043a\u043e\u043d\u0442\u0435\u043d\u0442\u0430 \u0434\u043b\u044f \u0440\u0430\u0441\u0447\u0435\u0442\u0430 \u0443\u0440\u043e\u0432\u043d\u044f \u0447\u0442\u0435\u043d\u0438\u044f."],"Adjust summary prompts in settings.":["\u041d\u0430\u0441\u0442\u0440\u043e\u0439\u0442\u0435 \u043f\u043e\u0434\u0441\u043a\u0430\u0437\u043a\u0438 \u0441\u0432\u043e\u0434\u043a\u0438 \u0432 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0430\u0445."],"Content at or below a 9th-grade reading level does not require a simplified summary.":["\u041a\u043e\u043d\u0442\u0435\u043d\u0442 \u043d\u0430 \u0443\u0440\u043e\u0432\u043d\u0435 \u0447\u0442\u0435\u043d\u0438\u044f 9-\u0433\u043e \u043a\u043b\u0430\u0441\u0441\u0430 \u0438\u043b\u0438 \u043d\u0438\u0436\u0435 \u043d\u0435 \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0443\u043f\u0440\u043e\u0449\u0435\u043d\u043d\u043e\u0439 \u0441\u0432\u043e\u0434\u043a\u0438."],"Content above a 9th-grade reading level requires a simplified summary to meet WCAG AAA guidance.":["\u041a\u043e\u043d\u0442\u0435\u043d\u0442 \u0432\u044b\u0448\u0435 \u0443\u0440\u043e\u0432\u043d\u044f \u0447\u0442\u0435\u043d\u0438\u044f 9-\u0433\u043e \u043a\u043b\u0430\u0441\u0441\u0430 \u0442\u0440\u0435\u0431\u0443\u0435\u0442 \u0443\u043f\u0440\u043e\u0449\u0435\u043d\u043d\u043e\u0439 \u0441\u0432\u043e\u0434\u043a\u0438 \u0434\u043b\u044f \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u044f \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u0430\u0446\u0438\u044f\u043c WCAG AAA."],"Learn more about readability requirements.":["\u0423\u0437\u043d\u0430\u0439\u0442\u0435 \u0431\u043e\u043b\u044c\u0448\u0435 \u043e \u0442\u0440\u0435\u0431\u043e\u0432\u0430\u043d\u0438\u044f\u0445 \u043a \u0447\u0438\u0442\u0430\u0431\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438."],"Simplified Summary Reading Level":["\u0423\u0440\u043e\u0432\u0435\u043d\u044c \u0447\u0442\u0435\u043d\u0438\u044f \u0443\u043f\u0440\u043e\u0449\u0435\u043d\u043d\u043e\u0439 \u0441\u0432\u043e\u0434\u043a\u0438"],"Needs improvement, summary is above the 9th-grade reading level.":["\u0422\u0440\u0435\u0431\u0443\u0435\u0442 \u0443\u043b\u0443\u0447\u0448\u0435\u043d\u0438\u044f, \u0441\u0432\u043e\u0434\u043a\u0430 \u0432\u044b\u0448\u0435 \u0443\u0440\u043e\u0432\u043d\u044f \u0447\u0442\u0435\u043d\u0438\u044f 9-\u0433\u043e \u043a\u043b\u0430\u0441\u0441\u0430."],"Below the recommended 9th-grade reading level.":["\u041d\u0438\u0436\u0435 \u0440\u0435\u043a\u043e\u043c\u0435\u043d\u0434\u043e\u0432\u0430\u043d\u043d\u043e\u0433\u043e \u0443\u0440\u043e\u0432\u043d\u044f \u0447\u0442\u0435\u043d\u0438\u044f 9-\u0433\u043e \u043a\u043b\u0430\u0441\u0441\u0430."],"Enter simplified summary...":["\u0412\u0432\u0435\u0434\u0438\u0442\u0435 \u0443\u043f\u0440\u043e\u0449\u0435\u043d\u043d\u0443\u044e \u0441\u0432\u043e\u0434\u043a\u0443..."],"A simplified summary is required for this content.":["\u0414\u043b\u044f \u044d\u0442\u043e\u0433\u043e \u043a\u043e\u043d\u0442\u0435\u043d\u0442\u0430 \u0442\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044f \u0443\u043f\u0440\u043e\u0449\u0435\u043d\u043d\u043e\u0435 \u0440\u0435\u0437\u044e\u043c\u0435."],"Unable to load this preference.":["\u041d\u0435 \u0443\u0434\u0430\u043b\u043e\u0441\u044c \u0437\u0430\u0433\u0440\u0443\u0437\u0438\u0442\u044c \u044d\u0442\u0443 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0443."],"Unable to save this preference.":["\u041d\u0435 \u0443\u0434\u0430\u043b\u043e\u0441\u044c \u0441\u043e\u0445\u0440\u0430\u043d\u0438\u0442\u044c \u044d\u0442\u0443 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0443."],"Loading preference...":["\u0417\u0430\u0433\u0440\u0443\u0437\u043a\u0430 \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438..."],"Screen Reader Text Format":["\u0424\u043e\u0440\u043c\u0430\u0442 \u0442\u0435\u043a\u0441\u0442\u0430 \u0434\u043b\u044f \u0447\u0442\u0435\u043d\u0438\u044f \u0441 \u044d\u043a\u0440\u0430\u043d\u0430"],"Control whether screen reader text stays visible while you edit.":["\u0423\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u0435 \u0432\u0438\u0434\u0438\u043c\u043e\u0441\u0442\u044c\u044e \u0442\u0435\u043a\u0441\u0442\u0430 \u0434\u043b\u044f \u0447\u0442\u0435\u043d\u0438\u044f \u0441 \u044d\u043a\u0440\u0430\u043d\u0430 \u0432\u043e \u0432\u0440\u0435\u043c\u044f \u0440\u0435\u0434\u0430\u043a\u0442\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u044f."],"Always show screen reader text?":["\u0412\u0441\u0435\u0433\u0434\u0430 \u043f\u043e\u043a\u0430\u0437\u044b\u0432\u0430\u0442\u044c \u0442\u0435\u043a\u0441\u0442 \u0434\u043b\u044f \u0447\u0442\u0435\u043d\u0438\u044f \u0441 \u044d\u043a\u0440\u0430\u043d\u0430?"],"Loading accessibility data...":["\u0417\u0430\u0433\u0440\u0443\u0437\u043a\u0430 \u0434\u0430\u043d\u043d\u044b\u0445 \u043e \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0438..."],"Accessibility Checker actions":["\u0414\u0435\u0439\u0441\u0442\u0432\u0438\u044f Accessibility Checker"],"Scan":["\u0421\u043a\u0430\u043d\u0438\u0440\u043e\u0432\u0430\u0442\u044c"],"Refresh":["\u041e\u0431\u043d\u043e\u0432\u0438\u0442\u044c"]}}}