<?php
/**
 * Generate Hooks Documentation.
 *
 * Scans the repository for add_action/add_filter calls and generates
 * `docs/hooks.md` containing a simple table of discovered hooks.
 *
 * Only hooks that are plugin-specific (prefixed with `edac_` or `edacp_`)
 * are included.
 *
 * @package AccessibilityChecker
 */

$root = dirname( __DIR__ );

// Configuration: allow overriding via environment variables for CI or local runs.
$github_owner  = getenv( 'GH_OWNER' ) ? getenv( 'GH_OWNER' ) : 'equalizedigital';
$github_repo   = getenv( 'GH_REPO' ) ? getenv( 'GH_REPO' ) : 'accessibility-checker';
$github_branch = getenv( 'GH_BRANCH' ) ? getenv( 'GH_BRANCH' ) : 'develop';

$rii = new RecursiveIteratorIterator(
	new RecursiveDirectoryIterator( $root )
);

/**
 * Find nearest docblock and extract information.
 *
 * @param string  $contents    File contents.
 * @param int     $pos         Position in the file.
 * @param int     $max_lines   Maximum number of lines allowed between docblock end and pos.
 * @param boolean $return_raw  Whether to return the raw docblock content.
 * @return array  Information extracted from the docblock including summary, since, params and return.
 */
function edac_find_nearest_docblock( $contents, $pos, $max_lines = 10, $return_raw = false ) {
	$leading = substr( $contents, 0, $pos );

	// Find all docblocks before the position.
	if ( preg_match_all( '/\/\*\*(?:[^*]|\*(?!\/))*\*\//s', $leading, $matches, PREG_OFFSET_CAPTURE ) ) {
		$last     = end( $matches[0] );
		$doc_text = $last[0];
		$doc_pos  = $last[1];
		$doc_end  = $doc_pos + strlen( $doc_text );

		// Lines between doc end and the hook position.
		$between  = substr( $contents, $doc_end, max( 0, $pos - $doc_end ) );
		$line_gap = substr_count( $between, "\n" );
		if ( $line_gap <= $max_lines ) {
			// Clean comment markers and collect lines.
			$lines = preg_split( '/\r?\n/', $doc_text );
			$clean = [];
			foreach ( $lines as $ln ) {
				$ln = preg_replace( '/^\s*\/\*\*\s?/', '', $ln );
				$ln = preg_replace( '/^\s*\*\s?/', '', $ln );
				$ln = preg_replace( '/\s*\*\/$/', '', $ln );
				$ln = trim( $ln );
				if ( '' !== $ln ) {
					$clean[] = $ln;
				}
			}

			$summary     = '';
			$since       = '';
			$params      = [];
			$return_info = [
				'type'        => '',
				'description' => '',
			];
			
			// Store the raw docblock for later use if requested.
			
			if ( ! empty( $clean ) ) {
				// Find first line that is not an @tag (e.g., not starting with @).
				foreach ( $clean as $c ) {
					if ( 0 === strpos( $c, '@' ) ) {
						continue;
					}
					$summary = $c;
					break;
				}

				// Extract all docblock tags.
				foreach ( $clean as $c ) {
					// Extract @since tag.
					if ( 0 === strpos( $c, '@since' ) ) {
						$parts = preg_split( '/\s+/', $c, 2 );
						$since = isset( $parts[1] ) ? $parts[1] : '';
					}
					
					// Extract @param information.
					if ( 0 === strpos( $c, '@param' ) && preg_match( '/@param\s+(\S+)\s+\$(\S+)(?:\s+(.+))?/', $c, $param_matches ) ) {
						$param_type = $param_matches[1];
						$param_name = $param_matches[2];
						$param_desc = isset( $param_matches[3] ) ? $param_matches[3] : '';
						
						$params[ $param_name ] = [
							'type'        => $param_type,
							'description' => $param_desc,
						];
					}
					
					// Extract @return information.
					if ( 0 === strpos( $c, '@return' ) && preg_match( '/@return\s+(\S+)(?:\s+(.+))?/', $c, $return_matches ) ) {
						$return_info['type']        = $return_matches[1];
						$return_info['description'] = isset( $return_matches[2] ) ? $return_matches[2] : '';
					}
				}
			}

			return [
				'summary'     => $summary,
				'since'       => $since,
				'params'      => $params,
				'return_info' => $return_info,
			];
		}
	}

	// Fallback: try to find the enclosing function's docblock (if any).
	if ( preg_match_all( '/function\s+[A-Za-z0-9_]+\s*\([^\)]*\)\s*\{?/s', $leading, $fn_matches, PREG_OFFSET_CAPTURE ) ) {
		$last_fn = end( $fn_matches[0] );
		$fn_pos  = $last_fn[1];

		// Find the last docblock before the function.
		if ( preg_match_all( '/\/\*\*(?:[^*]|\*(?!\/))*\*\//s', substr( $contents, 0, $fn_pos ), $m2, PREG_OFFSET_CAPTURE ) ) {
			$last2    = end( $m2[0] );
			$doc_text = $last2[0];

			// Clean and extract as above.
			$lines = preg_split( '/\r?\n/', $doc_text );
			$clean = [];
			foreach ( $lines as $ln ) {
				$ln = preg_replace( '/^\s*\/\*\*\s?/', '', $ln );
				$ln = preg_replace( '/^\s*\*\s?/', '', $ln );
				$ln = preg_replace( '/\s*\*\/$/', '', $ln );
				$ln = trim( $ln );
				if ( '' !== $ln ) {
					$clean[] = $ln;
				}
			}

			$summary     = '';
			$since       = '';
			$params      = [];
			$return_info = [
				'type'        => '',
				'description' => '',
			];
			
			if ( ! empty( $clean ) ) {
				// Find first non-tag line for summary.
				foreach ( $clean as $c ) {
					if ( 0 === strpos( $c, '@' ) ) {
						continue;
					}
					$summary = $c;
					break;
				}
				
				// Extract all tags.
				foreach ( $clean as $c ) {
					// Extract @since tag.
					if ( 0 === strpos( $c, '@since' ) ) {
						$parts = preg_split( '/\s+/', $c, 2 );
						$since = isset( $parts[1] ) ? $parts[1] : '';
					}
					
					// Extract @param information.
					if ( 0 === strpos( $c, '@param' ) && preg_match( '/@param\s+(\S+)\s+\$(\S+)(?:\s+(.+))?/', $c, $param_matches ) ) {
						$param_type = $param_matches[1];
						$param_name = $param_matches[2];
						$param_desc = isset( $param_matches[3] ) ? $param_matches[3] : '';
						
						$params[ $param_name ] = [
							'type'        => $param_type,
							'description' => $param_desc,
						];
					}
					
					// Extract @return information.
					if ( 0 === strpos( $c, '@return' ) && preg_match( '/@return\s+(\S+)(?:\s+(.+))?/', $c, $return_matches ) ) {
						$return_info['type']        = $return_matches[1];
						$return_info['description'] = isset( $return_matches[2] ) ? $return_matches[2] : '';
					}
				}
			}

			return [
				'summary'     => $summary,
				'since'       => $since,
				'params'      => $params,
				'return_info' => $return_info,
			];
		}
	}

	$result = [
		'summary'     => '',
		'since'       => '',
		'params'      => [],
		'return_info' => [
			'type'        => '',
			'description' => '',
		],
	];
	
	// Add raw docblock if requested.
	if ( $return_raw ) {
		$result['raw_docblock'] = '';
	}
	
	return $result;
}

// Collect candidates per hook so we can pick the single defining location.
$candidates = [];

foreach ( $rii as $file ) {
	if ( $file->isDir() ) {
		continue;
	}

	$filepath = $file->getPathname();

	// Skip vendor directory and non-PHP files.
	if ( false !== strpos( $filepath, DIRECTORY_SEPARATOR . 'vendor' . DIRECTORY_SEPARATOR ) ) {
		continue;
	}

	if ( ! preg_match( '/\.php$/', $filepath ) ) {
		continue;
	}

	$contents = file_get_contents( $filepath ); // phpcs:ignore WordPressVIPMinimum.Performance.FetchingRemoteData.FileGetContentsUnknown

	// 1) Find hook definitions: do_action (action) and apply_filters (filter).
	if ( preg_match_all( '/\b(do_action|apply_filters)\s*\(\s*([\'\"])([^\2]+?)\2/s', $contents, $def_matches, PREG_SET_ORDER | PREG_OFFSET_CAPTURE ) ) {
		foreach ( $def_matches as $row ) {
			$fn        = $row[1][0];
			$hook_name = $row[3][0];
			$pos       = $row[0][1];
			$line      = 1;
			if ( false !== $pos ) {
				$line = substr_count( substr( $contents, 0, $pos ), "\n" ) + 1;
			}

			if ( preg_match( '/^(edac_|edacp_)/', $hook_name ) ) {
				$relpath = substr( $filepath, strlen( $root ) + 1 );

				// Try to capture the nearest PHPDoc block (within 10 lines) for summary and @since.
				$doc_info                   = edac_find_nearest_docblock( $contents, $pos, 10, true );
				$candidates[ $hook_name ][] = [
					'hook'         => $hook_name,
					'type'         => ( 'do_action' === $fn ) ? 'action' : 'filter',
					'file'         => $relpath,
					'line'         => $line,
					'source'       => 'definition',
					'summary'      => $doc_info['summary'],
					'since'        => $doc_info['since'],
					'params'       => $doc_info['params'],
					'return_info'  => $doc_info['return_info'],
					'raw_docblock' => isset( $doc_info['raw_docblock'] ) ? $doc_info['raw_docblock'] : '',
				];
			}
		}
	}

	// 2) Find listeners (add_action/add_filter) - less authoritative for a definition.
	if ( preg_match_all( '/add_(action|filter)\s*\(\s*([\'\"])([^\2]+?)\2/', $contents, $matches_rows, PREG_SET_ORDER ) ) {
		foreach ( $matches_rows as $row ) {
			$hook_type = $row[1];
			$hook_name = $row[3];
			$pos       = strpos( $contents, $row[0] );
			$line      = 1;
			if ( false !== $pos ) {
				$line = substr_count( substr( $contents, 0, $pos ), "\n" ) + 1;
			}

			if ( preg_match( '/^(edac_|edacp_)/', $hook_name ) ) {
				$relpath = substr( $filepath, strlen( $root ) + 1 );

				// For listeners, also try to find a nearby docblock (within 6 lines).
				$doc_info = edac_find_nearest_docblock( $contents, $pos, 6 );

				$candidates[ $hook_name ][] = [
					'hook'        => $hook_name,
					'type'        => $hook_type,
					'file'        => $relpath,
					'line'        => $line,
					'source'      => 'listener',
					'summary'     => $doc_info['summary'],
					'since'       => $doc_info['since'],
					'params'      => $doc_info['params'],
					'return_info' => $doc_info['return_info'],
				];
			}
		}
	}
}

$github_base = sprintf( 'https://github.com/%s/%s/blob/%s/', $github_owner, $github_repo, $github_branch );

// Choose the best candidate per hook. Strategy: prefer definitions when present, and prefer files
// outside of tests/, dist/, build/, vendor/ etc.
$hooks = [];
foreach ( $candidates as $hook_name => $list ) {
	// First, filter out entries from non-authoritative directories.
	$filtered_list = array_filter(
		$list,
		static function ( $entry ) {
			// Skip entries from test/build/vendor directories.
			$excluded_paths = [
				'/tests/',
				'/dist/',
				'/build/',
				'/docs/',
				'/.github/',
				'/node_modules/',
				'/vendor/',
			];
			
			foreach ( $excluded_paths as $excluded_path ) {
				if ( false !== strpos( $entry['file'], $excluded_path ) ) {
					return false;
				}
			}
			return true;
		}
	);
	
	// If we filtered out everything, fall back to the original list.
	if ( ! empty( $filtered_list ) ) {
		$list = array_values( $filtered_list );
	}
	
	// If any definition candidates exist, narrow to them. Otherwise keep listeners.
	$defs = array_filter(
		$list,
		static function ( $e ) {
			return isset( $e['source'] ) && 'definition' === $e['source'];
		} 
	);
	if ( ! empty( $defs ) ) {
		$list = array_values( $defs );
	}

	$best = null;
	foreach ( $list as $entry ) {
		$score = 0;
		// Heuristics to penalize less-authoritative locations.
		if ( false !== strpos( $entry['file'], '/tests/' ) ) {
			$score += 1000;
		}
		if ( false !== strpos( $entry['file'], '/dist/' ) ) {
			$score += 800;
		}
		if ( false !== strpos( $entry['file'], '/build/' ) ) {
			$score += 600;
		}
		if ( false !== strpos( $entry['file'], '/vendor/' ) ) {
			$score += 500;
		}
		if ( false !== strpos( $entry['file'], '/docs/' ) ) {
			$score += 400;
		}
		if ( false !== strpos( $entry['file'], '/.github/' ) ) {
			$score += 300;
		}
		if ( false !== strpos( $entry['file'], '/node_modules/' ) ) {
			$score += 200;
		}

		// Lower line numbers are slightly preferred (first definition in file).
		$score = $score * 10000 + $entry['line'];

		if ( null === $best || $score < $best['score'] ) {
			$best          = $entry;
			$best['score'] = $score;
		}
	}

	if ( $best ) {
		$hooks[] = [
			'hook'         => $best['hook'],
			'type'         => $best['type'],
			'file'         => $best['file'],
			'line'         => $best['line'],
			'summary'      => isset( $best['summary'] ) ? $best['summary'] : '',
			'since'        => isset( $best['since'] ) ? $best['since'] : '',
			'params'       => isset( $best['params'] ) ? $best['params'] : [],
			'raw_docblock' => isset( $best['raw_docblock'] ) ? $best['raw_docblock'] : '',
			'return_info'  => isset( $best['return_info'] ) ? $best['return_info'] : [
				'type'        => '',
				'description' => '',
			],
		];
	}
}

usort(
	$hooks,
	static function ( $a, $b ) {
		return strcmp( $a['hook'], $b['hook'] );
	}
);

/**
 * Find or generate an example usage for a hook.
 * 
 * @param string $hook       The hook name.
 * @param string $type       Hook type ('action' or 'filter').
 * @param array  $params     Parameter information array.
 * @param array  $return_value Return value information (for filters).
 * @param string $docblock   Raw docblock content if available.
 * @return string Example usage as markdown code block.
 */
function edac_generate_hook_example( $hook, $type, $params, $return_value, $docblock = '' ) {
	// Check for a custom example in the docblock if provided.
	if ( ! empty( $docblock ) ) {
		// Check if we have an @example tag in the docblock.
		if ( strpos( $docblock, '@example' ) !== false ) {
			// Extract the example from the docblock.
			if ( preg_match( '/@example\s+(.*?)(\*\/|\*\s*@|\z)/s', $docblock, $matches ) ) {
				$example = trim( $matches[1] );
				// Clean up each line by removing leading asterisks and spaces.
				$example_lines = explode( "\n", $example );
				$cleaned_lines = [];
				foreach ( $example_lines as $line ) {
					$cleaned_line    = preg_replace( '/^\s*\*\s?/', '', $line );
					$cleaned_lines[] = $cleaned_line;
				}
				$example = trim( implode( "\n", $cleaned_lines ) );

				return "```php\n{$example}\n```";
			}
		}
	}
	
	// Generate standardized example based on the hook type, parameters and return value.
	$example_code = '';
	
	if ( 'filter' === $type ) {
		// Generate filter example.
		$hook_short  = str_replace( [ 'edac_', 'edacp_' ], '', $hook );
		$func_name   = 'my_custom_' . $hook_short;
		$param_count = count( $params );
		
		$example_code .= "/**\n";
		$example_code .= " * Customize {$hook_short}.\n";
		$example_code .= " *\n";
		$example_code .= ' * @param ';
		
		// First parameter type and description.
		$first_param_type = ! empty( $params ) && isset( array_values( $params )[0]['type'] ) ? array_values( $params )[0]['type'] : 'mixed';
		$example_code    .= $first_param_type . ' $' . key( $params ) . ' ';
		$param_desc       = isset( array_values( $params )[0]['description'] ) ? array_values( $params )[0]['description'] : 'Default value.';
		$example_code    .= $param_desc . "\n";
		
		// Additional parameters.
		$param_keys  = array_keys( $params );
		$param_count = count( $params );
		for ( $i = 1; $i < $param_count; $i++ ) {
			$param_name    = $param_keys[ $i ];
			$param_type    = isset( $params[ $param_name ]['type'] ) ? $params[ $param_name ]['type'] : 'mixed';
			$param_desc    = isset( $params[ $param_name ]['description'] ) ? $params[ $param_name ]['description'] : '';
			$example_code .= " * @param {$param_type} \${$param_name} {$param_desc}\n";
		}
		
		// Return value.
		$return_type   = isset( $return['type'] ) ? $return['type'] : 'mixed';
		$return_desc   = isset( $return['description'] ) ? $return['description'] : 'Modified value.';
		$example_code .= " * @return {$return_type} {$return_desc}\n";
		$example_code .= " */\n";
		
		// Filter registration.
		$example_code .= "add_filter( '{$hook}', '{$func_name}'";
		if ( $param_count > 0 ) {
			$example_code .= ", 10, {$param_count}";
		}
		$example_code .= " );\n\n";
		
		// Function implementation.
		$example_code .= "function {$func_name}( ";
		
		// Function parameters.
		$params_list = [];
		foreach ( array_keys( $params ) as $param_name ) {
			$params_list[] = '$' . $param_name;
		}
		$example_code .= implode( ', ', $params_list );
		$example_code .= " ) {\n";
		
		// Function body.
		if ( ! empty( $params ) ) {
			$first_param = '$' . key( $params );
			
			// Special cases for common hook patterns.
			if ( 'edac_scannable_post_statuses' === $hook ) {
				$example_code .= "    // Add a custom post status to the list\n";
				$example_code .= "    \$scannable_post_statuses[] = 'pending';\n";
				$example_code .= "\n";
				$example_code .= "    // Or remove a status if needed\n";
				$example_code .= "    \$key = array_search( 'draft', \$scannable_post_statuses, true );\n";
				$example_code .= "    if ( false !== \$key ) {\n";
				$example_code .= "        unset( \$scannable_post_statuses[\$key] );\n";
				$example_code .= "    }\n";
				$example_code .= "\n";
				$example_code .= "    return \$scannable_post_statuses;\n";
			} elseif ( 'edac_filter_fixes' === $hook ) {
				$example_code .= "    // Add your own custom fix\n";
				$example_code .= "    \$fixes[] = [\n";
				$example_code .= "        'id'          => 'my_custom_fix',\n";
				$example_code .= "        'title'       => 'My Custom Fix',\n";
				$example_code .= "        'description' => 'Description of the custom fix',\n";
				$example_code .= "    ];\n";
				$example_code .= "\n";
				$example_code .= "    return \$fixes;\n";
			} elseif ( 'edac_filter_command_classes' === $hook ) {
				$example_code .= "    // Add a custom WP-CLI command class\n";
				$example_code .= "    \$commands[] = '\\\\MyPlugin\\\\CLI\\\\MyCustomCommand';\n";
				$example_code .= "\n";
				$example_code .= "    return \$commands;\n";
			} elseif ( 'edac_debug_information' === $hook ) {
				$example_code .= "    // Add custom debugging information\n";
				$example_code .= "    \$information['my_plugin'] = [\n";
				$example_code .= "        'label'   => 'My Plugin',\n";
				$example_code .= "        'value'   => 'Version 1.0.0',\n";
				$example_code .= "        'private' => false,\n";
				$example_code .= "    ];\n";
				$example_code .= "\n";
				$example_code .= "    return \$information;\n";
			} elseif ( strpos( $first_param_type, 'array' ) !== false ) {
				$example_code .= "    // Add or modify entries in the {$hook_short} array\n";
				$example_code .= "    {$first_param}['custom_key'] = 'custom_value';\n";
				$example_code .= "\n";
				$example_code .= "    return {$first_param};\n";
			} elseif ( strpos( $first_param_type, 'string' ) !== false ) {
				$example_code .= "    // Modify the {$hook_short} string\n";
				$example_code .= "    {$first_param} .= ' (Modified by my plugin)';\n";
				$example_code .= "\n";
				$example_code .= "    return {$first_param};\n";
			} elseif ( strpos( $first_param_type, 'bool' ) !== false || strpos( $first_param_type, 'boolean' ) !== false ) {
				$example_code .= "    // Change the {$hook_short} behavior\n";
				$example_code .= "    return true; // Enable the feature\n";
				$example_code .= "    // return false; // Or disable it\n";
			} else {
				$example_code .= "    // Make your custom modifications to {$first_param}\n";
				$example_code .= "    \n";
				$example_code .= "    return {$first_param};\n";
			}
		} else {
			$example_code .= "    // Implement your custom logic here\n";
			$example_code .= "    return true;\n";
		}
		
		$example_code .= '}';
	} else {
		// Generate action example.
		$hook_short  = str_replace( [ 'edac_', 'edacp_' ], '', $hook );
		$func_name   = 'my_custom_' . $hook_short . '_handler';
		$param_count = count( $params );
		
		$example_code .= "/**\n";
		$example_code .= " * Handle the {$hook_short} action.\n";
		$example_code .= " *\n";
		
		// Parameters.
		foreach ( $params as $param_name => $param_info ) {
			$param_type    = isset( $param_info['type'] ) ? $param_info['type'] : 'mixed';
			$param_desc    = isset( $param_info['description'] ) ? $param_info['description'] : '';
			$example_code .= " * @param {$param_type} \${$param_name} {$param_desc}\n";
		}
		$example_code .= " */\n";
		
		// Action registration.
		$example_code .= "add_action( '{$hook}', '{$func_name}'";
		if ( $param_count > 0 ) {
			$example_code .= ", 10, {$param_count}";
		}
		$example_code .= " );\n\n";
		
		// Function implementation.
		$example_code .= "function {$func_name}( ";
		
		// Function parameters.
		$params_list = [];
		foreach ( array_keys( $params ) as $param_name ) {
			$params_list[] = '$' . $param_name;
		}
		$example_code .= implode( ', ', $params_list );
		$example_code .= " ) {\n";
		
		// Function body with example usage.
		if ( ! empty( $params ) ) {
			foreach ( array_keys( $params ) as $param_name ) {
				$param_var = '$' . $param_name;
				
				// Generate example code based on parameter name hints.
				if ( strpos( $param_name, 'post_id' ) !== false || strpos( $param_name, 'id' ) !== false ) {
					$example_code .= "    // Example: Get the post object from {$param_var}\n";
					$example_code .= "    \$post = get_post( {$param_var} );\n";
					$example_code .= "    if ( \$post ) {\n";
					$example_code .= "        // Do something with the post\n";
					$example_code .= "    }\n";
				} elseif ( strpos( $param_name, 'results' ) !== false || strpos( $param_name, 'data' ) !== false ) {
					$example_code .= "    // Example: Process the {$param_var} array\n";
					$example_code .= "    foreach ( {$param_var} as \$key => \$value ) {\n";
					$example_code .= "        // Process each item\n";
					$example_code .= "    }\n";
				} elseif ( strpos( $param_name, 'content' ) !== false || strpos( $param_name, 'text' ) !== false ) {
					$example_code .= "    // Example: Log or process the {$param_var} string\n";
					$example_code .= "    error_log( 'Content: ' . {$param_var} );\n";
				} else {
					$example_code .= "    // Example: Use {$param_var} in your custom logic\n";
				}
				
				$example_code .= "\n";
			}
		} else {
			$example_code .= "    // Implement your custom logic for the {$hook} action\n";
		}
		
		$example_code .= "    // Your custom code here\n";
		$example_code .= '}';
	}
	
	return "```php\n" . $example_code . "\n```";
}

$out  = "# EDAC Hooks Reference\n\n";
$out .= "This document is auto-generated by `tools/generate-hooks-docs.php`. It lists only plugin-specific hooks (prefixed with `edac_` or `edacp_`) and links files to the plugin's GitHub branch.\n\n";

// Group hooks by type (actions/filters).
$actions = array_filter(
	$hooks,
	static function ( $h ) {
		return 'action' === $h['type'];
	}
);
$filters = array_filter(
	$hooks,
	static function ( $h ) {
		return 'filter' === $h['type'];
	}
);

usort(
	$actions,
	static function ( $a, $b ) {
		return strcmp( $a['hook'], $b['hook'] );
	}
);
usort(
	$filters,
	static function ( $a, $b ) {
		return strcmp( $a['hook'], $b['hook'] );
	}
);

// Actions Table.
$out .= "## Actions\n\n";
$out .= "These are the actions provided by the Accessibility Checker plugin that you can hook into.\n\n";

foreach ( $actions as $entry ) {
	// Create a GitHub link for the file and line.
	$parts     = explode( DIRECTORY_SEPARATOR, $entry['file'] );
	$enc_parts = array_map( 'rawurlencode', $parts );
	$rel       = implode( '/', $enc_parts );
	$url       = $github_base . $rel . '#L' . $entry['line'];

	// Clean summary for table cell (escape pipes and newlines).
	$summary = str_replace( [ "\n", "\r", '|' ], [ ' ', ' ', '\|' ], $entry['summary'] );
	$since   = isset( $entry['since'] ) && ! empty( $entry['since'] ) ? $entry['since'] : 'N/A';

	// Action header.
	$out .= "### `{$entry['hook']}`\n\n";
	$out .= "*{$summary}*\n\n";
	
	// File location and version.
	$out .= "**Defined in:** [{$entry['file']}]({$url}) (line {$entry['line']})\n\n";
	$out .= "**Since:** {$since}\n\n";
	
	// Parameters section if available.
	if ( ! empty( $entry['params'] ) ) {
		$out .= "**Parameters:**\n\n";
		
		foreach ( $entry['params'] as $param_name => $param_data ) {
			$param_type = $param_data['type'];
			$param_desc = $param_data['description'];
			
			$out .= "- `\${$param_name}` ({$param_type}) - {$param_desc}\n";
		}
		$out .= "\n";
	}
	
	// Add example usage.
	$return_info = isset( $entry['return_info'] ) ? $entry['return_info'] : [];
	$example     = edac_generate_hook_example( $entry['hook'], 'action', $entry['params'], $return_info, $entry['raw_docblock'] );
	$out        .= "**Example Usage:**\n\n{$example}\n\n";
	
	$out .= "---\n\n";
}

// Filters Table.
$out .= "## Filters\n\n";
$out .= "These are the filters provided by the Accessibility Checker plugin that you can modify.\n\n";

foreach ( $filters as $entry ) {
	// Create a GitHub link for the file and line.
	$parts     = explode( DIRECTORY_SEPARATOR, $entry['file'] );
	$enc_parts = array_map( 'rawurlencode', $parts );
	$rel       = implode( '/', $enc_parts );
	$url       = $github_base . $rel . '#L' . $entry['line'];

	// Clean summary for table cell (escape pipes and newlines).
	$summary = str_replace( [ "\n", "\r", '|' ], [ ' ', ' ', '\|' ], $entry['summary'] );
	$since   = isset( $entry['since'] ) && ! empty( $entry['since'] ) ? $entry['since'] : 'N/A';

	// Filter header.
	$out .= "### `{$entry['hook']}`\n\n";
	$out .= "*{$summary}*\n\n";
	
	// File location and version.
	$out .= "**Defined in:** [{$entry['file']}]({$url}) (line {$entry['line']})\n\n";
	$out .= "**Since:** {$since}\n\n";
	
	// Parameters section if available.
	if ( ! empty( $entry['params'] ) ) {
		$out .= "**Parameters:**\n\n";
		
		foreach ( $entry['params'] as $param_name => $param_data ) {
			$param_type = $param_data['type'];
			$param_desc = $param_data['description'];
			
			$out .= "- `\${$param_name}` ({$param_type}) - {$param_desc}\n";
		}
		$out .= "\n";
	}
	
	// Return value if available.
	if ( ! empty( $entry['return_info']['type'] ) ) {
		$return_type = $entry['return_info']['type'];
		$return_desc = $entry['return_info']['description'];
		
		$out .= "**Returns:** ({$return_type}) {$return_desc}\n\n";
	}
	
	// Add example usage.
	$return_info = isset( $entry['return_info'] ) ? $entry['return_info'] : [];
	$example     = edac_generate_hook_example( $entry['hook'], 'filter', $entry['params'], $return_info, $entry['raw_docblock'] );
	$out        .= "**Example Usage:**\n\n{$example}\n\n";
	
	$out .= "---\n\n";
}

$docs_path = realpath( __DIR__ . '/..' ) . '/docs/hooks.md';
file_put_contents( $docs_path, $out ); // phpcs:ignore WordPressVIPMinimum.Functions.RestrictedFunctions.file_ops_file_put_contents

printf( "Generated docs/hooks.md with %d hooks.\n", count( $hooks ) );
